gpu_set_ztestenable(false);
gpu_set_zwriteenable(false);
draw_clear(c_aqua);
var BackgroundX = oCamera.CameraRotation * 0.8888888888888888;
shader_set(BillboardShader);
draw_sprite_ext(sBackground, 1, BackgroundX * -10, 180, 24, 1, 0, -1, 1);
draw_sprite_ext(sBackground, 0, BackgroundX * -8, 180, 24, 1, 0, -1, 1);
shader_reset();
gpu_set_ztestenable(true);
gpu_set_zwriteenable(true);
